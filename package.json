{
  "name": "@howells/things",
  "version": "0.1.0",
  "description": "CLI for Things 3 — read tasks from the database, write via URL scheme. Agent-first: structured JSON output, schema introspection, input validation, dry-run.",
  "type": "module",
  "license": "MIT",
  "author": "Daniel Howells <daniel.howells@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/howells/thingscli"
  },
  "homepage": "https://github.com/howells/thingscli#readme",
  "bugs": "https://github.com/howells/thingscli/issues",
  "keywords": [
    "things",
    "things3",
    "cli",
    "tasks",
    "todo",
    "macos",
    "agent",
    "ai",
    "automation"
  ],
  "os": ["darwin"],
  "bin": {
    "thingscli": "./dist/index.js"
  },
  "files": [
    "dist",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "howells-lint",
    "format": "howells-format",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@howells/lint": "^0.1.3",
    "@howells/typescript-config": "^0.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
